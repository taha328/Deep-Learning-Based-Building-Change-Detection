# Docker defaults. Copy to .env before running Docker Compose if you need overrides.
PYTHONNOUSERSITE=1
PYTHONUNBUFFERED=1
PYTHONPATH=/app/backend
# MODEL_DEVICE=auto resolves cuda when a CUDA-capable torch build can see an
# NVIDIA GPU, mps on native macOS when available, otherwise cpu. Use
# MODEL_DEVICE=cuda for explicit CUDA validation on NVIDIA hosts.
MODEL_DEVICE=auto
APP_INFERENCE_BACKEND=bandon_mps
# BANDON is the only supported inference backend.
APP_CHANGE_THRESHOLD=0.35
APP_SEMANTIC_THRESHOLD=0.50
PERSISTENCE_BACKEND=postgres
DATABASE_URL=postgresql+psycopg://building_change:building_change@postgres:5432/building_change
REDIS_URL=redis://redis:6379/0
APP_BANDON_ENV_PREFIX=/app/backend/.venv
APP_BANDON_REPO_DIR=/app/vendor/BANDON-mps
APP_BANDON_CONFIG_PATH=/app/vendor/BANDON-mps/workdirs_bandon/MTGCDNet/config.py
APP_BANDON_CHECKPOINT_PATH=/models/bandon/mtgcdnet_iter_40000.pth
APP_RUNTIME_CACHE_DIR=/data/runtime_cache
APP_WAYBACK_METADATA_WORKERS=10
APP_WAYBACK_METADATA_WORKERS_ADAPTIVE_ENABLED=true
APP_WAYBACK_METADATA_WORKERS_INITIAL=10
APP_WAYBACK_METADATA_WORKERS_MIN=4
APP_WAYBACK_METADATA_WORKERS_STEP=2

# The BANDON checkpoint is not baked into the image.
# Mount it at ./vendor/BANDON-mps/checkpoints/mtgcdnet_iter_40000.pth.

# CUDA Docker additionally requires an NVIDIA GPU, compatible host driver,
# NVIDIA Container Toolkit, and Docker Compose GPU support. Mac Docker is not
# a CUDA target; native macOS MPS uses the local, non-Docker runtime path.
