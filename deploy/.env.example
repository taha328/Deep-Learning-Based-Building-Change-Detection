# Copy this file to .env before running the packaged deployment.
COMPOSE_PROJECT_NAME=building-change

BACKEND_IMAGE=ghcr.io/taha328/building-change-backend:cpu-v0.1.5
BACKEND_CUDA_IMAGE=ghcr.io/taha328/building-change-backend:cuda-v0.1.0
FRONTEND_IMAGE=ghcr.io/taha328/building-change-frontend:v0.1.5
POSTGIS_IMAGE=imresamu/postgis:16-3.4

FRONTEND_PORT=8080
BACKEND_PORT=8000
# Public browser token used by the Docker frontend runtime config.
# Never use a secret sk. token here.
MAPBOX_API_KEY=pk.eyJ1IjoidGFoYWVsIiwiYSI6ImNtbnl6dHdqcjA3Z3EycXNmZHQyM3FkZWQifQ.IDf_zeGoMaPHcrsLOD5q7A
# Public token used by backend Mapbox current-imagery workflows when enabled.
MAPBOX_ACCESS_TOKEN=pk.eyJ1IjoidGFoYWVsIiwiYSI6ImNtbnl6dHdqcjA3Z3EycXNmZHQyM3FkZWQifQ.IDf_zeGoMaPHcrsLOD5q7A

MODEL_DEVICE=auto
# Packaged deployment supports BANDON only; keep this paired with APP_BANDON_CHECKPOINT_PATH below.
APP_INFERENCE_BACKEND=bandon_mps
APP_CHANGE_THRESHOLD=0.50
APP_SEMANTIC_THRESHOLD=0.50
APP_MAPBOX_MAX_TILES_PER_REQUEST=1024
MAPBOX_CURRENT_IMAGERY_MAX_TILES=1024
APP_WAYBACK_DEFAULT_ZOOM=18
APP_TILE_ZOOM=18
APP_WAYBACK_HTTP_CONNECT_TIMEOUT_SECONDS=60
APP_WAYBACK_HTTP_READ_TIMEOUT_SECONDS=120
APP_WAYBACK_HTTP_MAX_RETRIES=8
APP_WAYBACK_HTTP_BACKOFF_BASE_SECONDS=1.0
APP_WAYBACK_TILE_MAX_CONCURRENCY=12
APP_WAYBACK_MAX_MISSING_TILE_RATIO=0.05
APP_POST_COMPLETION_REQUEST_CLEANUP_ENABLED=true
APP_POST_COMPLETION_REQUEST_CLEANUP_MODE=compact_heavy
APP_POST_COMPLETION_REQUEST_CLEANUP_GRACE_SECONDS=300
APP_POST_COMPLETION_REQUEST_CLEANUP_KEEP_PROVENANCE=true
APP_POST_COMPLETION_REQUEST_CLEANUP_DELETE_EXPORT_BUNDLE=true

POSTGRES_DB=building_change
POSTGRES_USER=building_change
POSTGRES_PASSWORD=change_me_before_shared_deployment

PERSISTENCE_BACKEND=postgres
DATABASE_URL=postgresql+psycopg://building_change:change_me_before_shared_deployment@postgres:5432/building_change
REDIS_URL=redis://redis:6379/0

APP_BANDON_ENV_PREFIX=/app/backend/.venv
APP_BANDON_REPO_DIR=/app/vendor/BANDON-mps
APP_BANDON_CONFIG_PATH=/app/vendor/BANDON-mps/workdirs_bandon/MTGCDNet/config.py
APP_BANDON_CHECKPOINT_PATH=/models/bandon/mtgcdnet_iter_40000.pth
APP_RUNTIME_CACHE_DIR=/data/runtime_cache
APP_WAYBACK_METADATA_WORKERS=10
APP_WAYBACK_METADATA_WORKERS_ADAPTIVE_ENABLED=true
APP_WAYBACK_METADATA_WORKERS_INITIAL=10
APP_WAYBACK_METADATA_WORKERS_MIN=4
APP_WAYBACK_METADATA_WORKERS_STEP=2

CORS_ALLOWED_ORIGINS=http://127.0.0.1:8080,http://localhost:8080
CORS_ALLOW_ORIGIN_REGEX=

# Place the BANDON checkpoint here before starting:
#   deploy/models/bandon/mtgcdnet_iter_40000.pth
#
# CUDA is optional and not the supported default. It requires NVIDIA GPU,
# compatible drivers, Docker GPU support, and separate target-machine validation.
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility
