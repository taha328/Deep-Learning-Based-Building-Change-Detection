PERSISTENCE_BACKEND=filesystem
DATABASE_URL=postgresql+psycopg://building_change:building_change@localhost:5432/building_change
DATABASE_ECHO=false
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_TASK_DEFAULT_QUEUE=building_change
CELERY_WORKER_POOL=solo
CELERY_WORKER_CONCURRENCY=1
CELERY_TASK_ACKS_LATE=false
CELERY_TASK_REJECT_ON_WORKER_LOST=false
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_JOB_STALE_AFTER_MINUTES=60
JOBS_ENABLED=true
KEEP_INTERMEDIATE_ARTIFACTS=false
MATERIALIZE_SOURCE_IMAGERY_IN_REQUESTS=false
WAYBACK_METADATA_CACHE_ENABLED=true
WAYBACK_METADATA_CACHE_TTL_SECONDS=604800
WAYBACK_METADATA_CACHE_DIR=runtime_cache/wayback_metadata_cache
WAYBACK_TILE_PREFLIGHT_CACHE_ENABLED=true
WAYBACK_TILE_PREFLIGHT_CACHE_TTL_SECONDS=604800
WAYBACK_TILE_PREFLIGHT_CACHE_DIR=runtime_cache/wayback_tile_preflight_cache
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_ORIGIN_REGEX=http://(localhost|127\.0\.0\.1):\d+
PYTHONNOUSERSITE=1
